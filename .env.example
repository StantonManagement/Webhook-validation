# Collections Backend API - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================
# Your Supabase project URL - find this in your Supabase dashboard
SUPABASE_URL=https://[your-project-id].supabase.co

# Your Supabase anon/public key - find this in Settings > API
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_key_here

# =============================================================================
# COLLECTIONS MONITOR API (Optional)
# =============================================================================
# URL for Kurt's Collections Monitor API
# If not available, the service will use mock data
MONITOR_API_URL=http://localhost:8001

# =============================================================================
# CORS CONFIGURATION (Frontend Access)
# =============================================================================
# Frontend dashboard URL for CORS configuration
# Multiple URLs can be comma-separated: http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# =============================================================================
# SERVER CONFIGURATION (Optional)
# =============================================================================
# Server host (0.0.0.0 for Docker, localhost for local dev)
HOST=localhost

# Server port
PORT=8000

# =============================================================================
# LOGGING CONFIGURATION (Optional)
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# DEVELOPMENT SETTINGS (Optional)
# =============================================================================
# Enable development mode with detailed error messages
DEBUG=false

# Enable automatic reload on code changes (development only)
RELOAD=false

# =============================================================================
# EXAMPLE PRODUCTION VALUES
# =============================================================================
# For production deployment, use values like:
# SUPABASE_URL=https://abcdefghijklmnopqrst.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFiY2RlZmdoaWprbG1ub3BxcnN0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE2NzAwMDAwMDAsImV4cCI6MTk4NTU3NjAwMH0.example-key
# MONITOR_API_URL=https://collections-monitor.yourcompany.com
# FRONTEND_URL=https://dashboard.yourcompany.com
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=WARNING